# Clinic-Q Docker Environment Configuration
# Copy this file to docker.env and edit the values before running docker-compose

# ─────────────────────────────────────────────
# REQUIRED: Set a strong password for the database
# ─────────────────────────────────────────────
DB_PASSWORD=change_me_to_a_strong_password

# ─────────────────────────────────────────────
# OPTIONAL: Port the app will listen on (default: 3001)
# Change this if port 3001 is already in use on your server
# ─────────────────────────────────────────────
PORT=3001
