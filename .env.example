# ─────────────────────────────────────────────────────────
#  Clinic-Q — Environment Configuration
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ─────────────────────────────────────────────────────────

# ── DATABASE PASSWORD ─────────────────────────────────────
# Used by Docker to create the Postgres container.
# Also embedded in DATABASE_URL below — keep them the same.
DB_PASSWORD=change_me_to_a_strong_password

# ── DATABASE URL ──────────────────────────────────────────
# Used by the Node server to connect to Postgres.
#
# WITH DOCKER (docker-compose): leave as-is — 'db' is the
#   Postgres container name inside Docker network.
DATABASE_URL=postgresql://clinicq:change_me_to_a_strong_password@db:5432/clinicq
#
# WITHOUT DOCKER (local Postgres or cloud Postgres):
#   Replace with your actual host, e.g.:
#   DATABASE_URL=postgresql://clinicq:yourpassword@localhost:5432/clinicq
#   DATABASE_URL=postgresql://user:pass@your-rds-host.amazonaws.com:5432/clinicq

# ── PORT ──────────────────────────────────────────────────
# Port the app listens on. Default: 3001
PORT=3001
